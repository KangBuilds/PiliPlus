platform :ios, '26.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!
  inhibit_all_warnings!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  # ponytail: remove when permission_handler_apple adds its own include guard.
  Dir.glob(File.join(__dir__, 'Flutter/ephemeral/Packages/.packages/permission_handler_apple-*/Sources/permission_handler_apple/PermissionHandlerEnums.h')).each do |header|
    contents = File.read(header)
    File.write(header, "#pragma once\n#{contents}") unless contents.start_with?('#pragma once')
  end

  webview_storyboard = File.join(__dir__, '.symlinks/plugins/flutter_inappwebview_ios/ios/Storyboards/WebView.storyboard')
  if File.exist?(webview_storyboard) && (storyboard = File.read(webview_storyboard)).sub!(' version="2048"', '')
    File.write(webview_storyboard, storyboard)
  end

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '26.0'
      # ponytail: suppress vendored Swift warnings until the plugins support the current SDK.
      config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'
      next unless target.name == 'permission_handler_apple'

      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_PHOTOS=1',
      ]
    end
  end
  installer.pods_project.root_object.attributes['LastUpgradeCheck'] = '2660'
end
